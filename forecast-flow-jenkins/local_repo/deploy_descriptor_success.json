{
	"DeployDescriptor": [
		{
			"Comment": "Rename folders for PROD standard",
			"Property": "@",
			"ApplyOn": {
				"Type": "Folder"
			},
			"Replace": [
				{
					"replace_with_usercode(.*)": "replace_with_usercode$1-PROD"
				}
			]
		},
		{
			"Property": "Application",
			"Replace": [
				{
					"replace_with_usercode(.*)": "replace_with_usercode$1-PROD"
				}
			]
		},
		{
			"Property": "SubApplication",
			"Replace": [
				{
					"replace_with_usercode(.*)": "replace_with_usercode$1-PROD"
				}
			]
		},
		{
			"ApplyOn": {
				"Type": "Folder"
			},
			"Property": "SiteStandard",
			"Assign": "Prod_SiteStandard"

		}
	]
}
